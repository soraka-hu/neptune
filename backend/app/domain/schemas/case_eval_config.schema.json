{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case Evaluation Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evaluation_mode", "evaluators", "threshold"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "evaluation_mode": {
      "type": "string",
      "enum": ["with_reference", "without_reference"]
    },
    "evaluators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "weight"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "weight": {
            "type": "number"
          },
          "rubric_id": {
            "type": "integer"
          }
        }
      }
    },
    "threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
