{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "API Case Input Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "method", "path"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "query": {
      "type": "object"
    },
    "body": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "context_vars": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
